generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  password              String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  categories            Category[]
  installments          Installment[]
  ledgerEntries         LedgerEntry[]
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]
  transfers             Transfer[]
  vehicles              Vehicle[]
  creditCards           CreditCard[]
}

model Account {
  id                    String                 @id @default(uuid())
  name                  String
  balance               Float                  @default(0)
  userId                String
  createdAt             DateTime               @default(now())
  color                 String?
  initialBalance        Float                  @default(0)
  isActive              Boolean                @default(true)
  type                  AccountType            @default(CHECKING)
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  user                  User                   @relation(fields: [userId], references: [id])
  installments          Installment[]
  ledgerEntries         LedgerEntry[]
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]
  sentTransfers         Transfer[]             @relation("TransferFromAccount")
  receivedTransfers     Transfer[]             @relation("TransferToAccount")
}

model Category {
  id                    String                 @id @default(uuid())
  name                  String
  type                  CategoryType
  userId                String?
  color                 String?
  createdAt             DateTime               @default(now())
  description           String?
  icon                  String?
  isDefault             Boolean                @default(false)
  isVehicleCategory     Boolean                @default(false)
  parentId              String?
  slug                  String
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  parent                Category?              @relation("CategoryChildren", fields: [parentId], references: [id])
  children              Category[]             @relation("CategoryChildren")
  user                  User?                  @relation(fields: [userId], references: [id])
  installments          Installment[]
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]

  @@unique([slug, userId])
}

model Vehicle {
  id           String        @id @default(uuid())
  name         String
  brand        String
  model        String
  year         Int
  plate        String?
  currentKm    Float         @default(0)
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  fuelSupplies FuelSupply[]
  maintenances Maintenance[]
  user         User          @relation(fields: [userId], references: [id])
}

model FuelSupply {
  id                 String       @id @default(uuid())
  vehicleId          String
  transactionId      String?      @unique
  fuelType           FuelType
  liters             Float
  pricePerLiter      Float
  totalAmount        Float
  odometer           Float
  fullTank           Boolean      @default(false)
  averageKmPerLiter  Float?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  averageCostPerKm   Float?
  notes              String?
  previousFullTankId String?
  deletedAt          DateTime?
  previousFullTank   FuelSupply?  @relation("FuelSupplyHistory", fields: [previousFullTankId], references: [id])
  nextFullTanks      FuelSupply[] @relation("FuelSupplyHistory")
  transaction        Transaction? @relation(fields: [transactionId], references: [id])
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([fullTank])
  @@index([createdAt])
}

model Maintenance {
  id                String          @id @default(uuid())
  vehicleId         String
  transactionId     String?         @unique
  type              MaintenanceType
  description       String
  cost              Float
  odometer          Float?
  workshop          String?
  createdAt         DateTime        @default(now())
  nextMaintenanceAt DateTime?
  nextMaintenanceKm Float?
  performedAt       DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  transaction       Transaction?    @relation(fields: [transactionId], references: [id])
  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id])
}

model Transaction {
  id           String             @id @default(uuid())
  title        String
  amount       Float
  type         TransactionType
  date         DateTime
  userId       String
  createdAt    DateTime           @default(now())
  accountId    String
  categoryId   String
  description  String?
  deletedAt    DateTime?
  updatedAt    DateTime           @default(now()) @updatedAt
  creditCardId String?
  invoiceId    String?
  fuelSupply   FuelSupply?
  installments Installment?
  maintenance  Maintenance?
  account      Account            @relation(fields: [accountId], references: [id])
  category     Category           @relation(fields: [categoryId], references: [id])
  creditCard   CreditCard?        @relation(fields: [creditCardId], references: [id])
  invoice      CreditCardInvoice? @relation("InvoiceTransactions", fields: [invoiceId], references: [id])
  user         User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([type])
  @@index([date])
}

model Transfer {
  id            String    @id @default(uuid())
  amount        Float
  description   String?
  userId        String
  fromAccountId String
  toAccountId   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  fromAccount   Account   @relation("TransferFromAccount", fields: [fromAccountId], references: [id])
  toAccount     Account   @relation("TransferToAccount", fields: [toAccountId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model LedgerEntry {
  id            String               @id @default(uuid())
  userId        String
  accountId     String
  type          LedgerEntryType
  amount        Float
  description   String?
  referenceId   String?
  referenceType LedgerReferenceType?
  createdAt     DateTime             @default(now())
  account       Account              @relation(fields: [accountId], references: [id])
  user          User                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([referenceType])
  @@index([referenceId])
  @@index([createdAt])
}

model RecurringTransaction {
  id            String              @id @default(uuid())
  title         String
  description   String?
  amount        Decimal             @db.Decimal(12, 2)
  type          TransactionType
  frequency     RecurrenceFrequency
  startDate     DateTime
  endDate       DateTime?
  nextExecution DateTime
  active        Boolean             @default(true)
  userId        String
  accountId     String
  categoryId    String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  account       Account             @relation(fields: [accountId], references: [id])
  category      Category            @relation(fields: [categoryId], references: [id])
  user          User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([nextExecution])
}

model Installment {
  id                 String       @id @default(uuid())
  title              String
  description        String?
  totalAmount        Float
  installmentAmount  Float
  totalInstallments  Int
  currentInstallment Int
  purchaseDate       DateTime
  dueDate            DateTime
  paid               Boolean      @default(false)
  accountId          String
  categoryId         String
  userId             String
  transactionId      String?      @unique
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  account            Account      @relation(fields: [accountId], references: [id])
  category           Category     @relation(fields: [categoryId], references: [id])
  transaction        Transaction? @relation(fields: [transactionId], references: [id])
  user               User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([dueDate])
  @@index([paid])
}

model CreditCard {
  id           String              @id @default(uuid())
  name         String
  bank         String
  brand        String
  limit        Float
  closingDay   Int
  dueDay       Int
  active       Boolean             @default(true)
  userId       String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  transactions Transaction[]
  invoices     CreditCardInvoice[]
  user         User                @relation(fields: [userId], references: [id])

  @@map("credit_cards")
}

model CreditCardInvoice {
  id             String        @id @default(uuid())
  referenceMonth String
  totalAmount    Float         @default(0)
  dueDate        DateTime
  status         InvoiceStatus @default(OPEN)
  paidAt         DateTime?
  creditCardId   String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  transactions   Transaction[] @relation("InvoiceTransactions")
  creditCard     CreditCard    @relation(fields: [creditCardId], references: [id])

  @@map("credit_card_invoices")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  FLEX
  ELECTRIC
  GNV
}

enum MaintenanceType {
  MECHANICAL
  ELECTRICAL
  TIRE_SHOP
  OIL_CHANGE
  OTHER
  ALIGNMENT
  BALANCING
  BRAKES
  SUSPENSION
  ENGINE
  BATTERY
}

enum AccountType {
  CASH
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum LedgerReferenceType {
  TRANSACTION
  TRANSFER
  FUEL_SUPPLY
  MAINTENANCE
  VEHICLE
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  OPEN
  CLOSED
  PAID
  OVERDUE
}
