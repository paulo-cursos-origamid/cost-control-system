datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  vehicles     Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id      String @id @default(uuid())
  name    String
  balance Float  @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())
}

model Category {
  id   String       @id @default(uuid())
  name String
  type CategoryType

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]
}

model Vehicle {
  id String @id @default(uuid())

  name  String
  brand String
  model String

  year Int

  plate String?

  currentKm Float @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  fuelSupplies FuelSupply[]
  maintenances Maintenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FuelSupply {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactionId String? @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  fuelType FuelType

  liters Float

  pricePerLiter Float

  totalAmount Float

  odometer Float

  fullTank Boolean @default(false)

  averageKmPerLiter Float?

  createdAt DateTime @default(now())
}

model Maintenance {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactionId String? @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  type MaintenanceType

  description String
  

  cost Float

  odometer Float?

  workshop String?

  createdAt DateTime @default(now())
}

model Transaction {
  id     String          @id @default(uuid())
  title  String
  amount Float
  type   TransactionType
  date   DateTime

  userId     String
  accountId  String
  categoryId String

  user     User     @relation(fields: [userId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  fuelSupply  FuelSupply?
  maintenance Maintenance?

  createdAt DateTime @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  FLEX
  ELECTRIC
}

enum MaintenanceType {
  MECHANICAL
  ELECTRICAL
  TIRE_SHOP
  OIL_CHANGE
  OTHER
}
