datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  accounts              Account[]
  categories            Category[]
  transactions          Transaction[]
  vehicles              Vehicle[]
  transfers             Transfer[]
  ledgerEntries         LedgerEntry[]
  recurringTransactions RecurringTransaction[]
  installments          Installment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id String @id @default(uuid())

  name String

  type AccountType @default(CHECKING)

  balance Float @default(0)

  initialBalance Float @default(0)

  color String?

  isActive Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  sentTransfers Transfer[] @relation("TransferFromAccount")

  receivedTransfers     Transfer[]             @relation("TransferToAccount")
  ledgerEntries         LedgerEntry[]
  recurringTransactions RecurringTransaction[]
  installments          Installment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Category {
  id String @id @default(uuid())

  name String

  slug String

  description String?

  icon String?

  color String?

  type CategoryType

  isDefault Boolean @default(false)

  isVehicleCategory Boolean @default(false)

  parentId String?

  parent Category? @relation("CategoryChildren", fields: [parentId], references: [id])

  children Category[] @relation("CategoryChildren")

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  installments          Installment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([slug, userId])
}

model Vehicle {
  id String @id @default(uuid())

  name  String
  brand String
  model String

  year Int

  plate String?

  currentKm Float @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  fuelSupplies FuelSupply[]
  maintenances Maintenance[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model FuelSupply {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  fuelType FuelType

  liters Float

  pricePerLiter Float

  totalAmount Float

  odometer Float

  fullTank Boolean @default(false)

  averageKmPerLiter Float?

  averageCostPerKm Float?

  previousFullTankId String?

  previousFullTank FuelSupply? @relation("FuelSupplyHistory", fields: [previousFullTankId], references: [id])

  nextFullTanks FuelSupply[] @relation("FuelSupplyHistory")

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([vehicleId])
  @@index([fullTank])
  @@index([createdAt])
}

model Maintenance {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  type MaintenanceType

  description String

  cost Float

  odometer Float?

  workshop String?

  performedAt DateTime @default(now())

  nextMaintenanceAt DateTime?

  nextMaintenanceKm Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Transaction {
  id          String          @id @default(uuid())
  title       String
  description String?
  amount      Float
  type        TransactionType
  date        DateTime

  userId     String
  accountId  String
  categoryId String

  user     User     @relation(fields: [userId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  fuelSupply  FuelSupply?
  maintenance Maintenance?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  deletedAt    DateTime?
  installments Installment?

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([type])
  @@index([date])
}

model Transfer {
  id String @id @default(uuid())

  amount Float

  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  fromAccountId String
  toAccountId   String

  fromAccount Account @relation("TransferFromAccount", fields: [fromAccountId], references: [id])

  toAccount Account @relation("TransferToAccount", fields: [toAccountId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model LedgerEntry {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  type LedgerEntryType

  amount Float

  description String?

  referenceId String?

  referenceType LedgerReferenceType?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([referenceType])
  @@index([referenceId])
  @@index([createdAt])
}

model RecurringTransaction {
  id String @id @default(uuid())

  title       String
  description String?

  amount Decimal @db.Decimal(12, 2)

  type TransactionType

  frequency RecurrenceFrequency

  startDate DateTime
  endDate   DateTime?

  nextExecution DateTime

  active Boolean @default(true)

  userId     String
  accountId  String
  categoryId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([nextExecution])
}

model Installment {
  id String @id @default(uuid())

  title String

  description String?

  totalAmount Float

  installmentAmount Float

  totalInstallments Int

  currentInstallment Int

  purchaseDate DateTime

  dueDate DateTime

  paid Boolean @default(false)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactionId String? @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([dueDate])
  @@index([paid])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  FLEX
  GNV
  ELECTRIC
}

enum MaintenanceType {
  MECHANICAL
  ELECTRICAL
  TIRE_SHOP
  OIL_CHANGE
  ALIGNMENT
  BALANCING
  BRAKES
  SUSPENSION
  ENGINE
  BATTERY
  OTHER
}

enum AccountType {
  CASH
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum LedgerReferenceType {
  TRANSACTION
  TRANSFER
  MAINTENANCE
  FUEL_SUPPLY
  VEHICLE
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}
